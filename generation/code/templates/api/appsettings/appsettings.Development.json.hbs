{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Debug",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "ConnectionStrings": {
    "{{contextName}}Database": "Host=localhost;Port={{dbPort}};Database={{databaseName}}_dev;Username=postgres;Password=postgres"
  }{{#if jwt}},
  "JwtSettings": {
    "SecretKey": "{{#if jwt.devSecretKey}}{{jwt.devSecretKey}}{{else}}{{#if jwt.secretKey}}{{jwt.secretKey}}{{else}}dev-secret-key-change-in-production-min-32-chars-dev{{/if}}{{/if}}",
    "Issuer": "{{#if jwt.devIssuer}}{{jwt.devIssuer}}{{else}}{{jwt.issuer}}.Dev{{/if}}",
    "Audience": "{{#if jwt.devAudience}}{{jwt.devAudience}}{{else}}{{jwt.audience}}.Dev{{/if}}",
    "ExpirationMinutes": {{#if jwt.devExpirationMinutes}}{{jwt.devExpirationMinutes}}{{else}}{{jwt.expirationMinutes}}{{/if}}
  }{{/if}}{{#if onlineAuthEnabled}},
  "OnlineAuth": {
    "AuthServiceBaseUrl": "{{onlineAuth.authServiceUrl}}",
    "CacheTtlSeconds": {{onlineAuth.cacheTtlSeconds}},
    "FailOpen": {{onlineAuth.failOpen}},
    "Transport": "{{onlineAuth.transport}}",
    "TimeoutSeconds": {{onlineAuth.timeoutSeconds}}
  }{{/if}}
}
